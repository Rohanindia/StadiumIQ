# StadiumIQ — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── Groq API ─────────────────────────────────────────────────────────────────
# Get from: https://console.groq.com/keys
VITE_GROQ_API_KEY=your_groq_api_key_here

# ── Firebase ─────────────────────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Your apps
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Google Maps ───────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/google/maps-apis
# Enable: Maps Embed API, Maps JavaScript API
VITE_MAPS_KEY=your_google_maps_api_key_here

# ── App ───────────────────────────────────────────────────────────────────────
# Set to 'true' during development to enable console.log
VITE_IS_DEV=false
